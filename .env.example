# Copy to .env and fill in your Google Earth Engine Cloud project id.
# This is the project that has the Earth Engine API enabled.
GEE_PROJECT=your-gcp-project-id

# Google Gemini API key — powers the "Generate AI briefing" button on placed
# solar farms (server-side only; never exposed to the browser). Gemini Flash has
# a free tier — get a key at https://aistudio.google.com/apikey. Without it the
# briefing button shows a friendly message and the rest of the app works unchanged.
GEMINI_API_KEY=
# Optional: override the model (defaults to gemini-2.5-flash). If your key reports
# a free-tier limit of 0 for one model, try another (e.g. gemini-2.5-flash-lite).
# GEMINI_MODEL=gemini-2.5-flash
